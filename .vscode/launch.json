{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: FastAPI (apps/api)",
      "type": "debugpy",
      "request": "launch",
      "module": "apps.api.run",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "Web: Next.js Dev (apps/web)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/apps/web"
    }
  ],
  "compounds": [
    {
      "name": "Athena Web MVP: API + Web",
      "configurations": [
        "API: FastAPI (apps/api)",
        "Web: Next.js Dev (apps/web)"
      ],
      "stopAll": true
    }
  ]
}
