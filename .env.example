DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Runtime tuning
ANALYSIS_MAX_CONCURRENT=3
REQUEST_QUEUE_MAXSIZE=100
USER_COOLDOWN_SECONDS=20
REQUEST_TIMEOUT_SECONDS=15
RETRY_ATTEMPTS=1
ANALYSIS_CACHE_TTL_SECONDS=180
TICKER_INFO_CACHE_TTL_SECONDS=86400
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_FILE_PATH=/tmp/athena_heartbeat
LOG_LEVEL=INFO

# Fear & Greed
ENABLE_FEAR_GREED_SCHEDULER=true
FEAR_GREED_INTERVAL_MINUTES=60
WEBHOOK_URL=
WEBHOOK_FEAR_AND_GREED=

# Optional controlled shutdown (mainly for CI)
# RUN_DURATION_HOURS=4.9

# Web API
WEB_API_HOST=0.0.0.0
WEB_API_PORT=8000
WEB_API_CORS_ORIGINS=http://localhost:3000
WEB_API_REQUEST_TIMEOUT_SECONDS=20
WEB_API_RETRY_ATTEMPTS=1
WEB_API_ANALYSIS_CACHE_TTL_SECONDS=180
WEB_API_TICKER_INFO_CACHE_TTL_SECONDS=86400
WEB_API_RATE_LIMIT_WINDOW_SECONDS=60
WEB_API_RATE_LIMIT_ANALYSIS_REQUESTS=20
WEB_API_RATE_LIMIT_CHAT_REQUESTS=12
WEB_API_ENABLE_INTERNAL_SCHEDULERS=true
WEB_API_MARKET_REFRESH_INTERVAL_SECONDS=300
WEB_API_WATCHLIST_DB_PATH=data/watchlist.db
WEB_API_WATCHLIST_MAX_ITEMS=5
WEB_API_WATCHLIST_REFRESH_INTERVAL_SECONDS=3600
WEB_API_WATCHLIST_SIGNIFICANT_CHANGE_PCT=5
WEB_API_WATCHLIST_DEGRADED_FAILURE_THRESHOLD=3
WEB_API_WATCHLIST_RETENTION_DAYS=90

# Neon / Vercel Postgres (for local + production)
# Use pooled connection string (host includes "-pooler")
DATABASE_URL=
# Optional fallback name used by Vercel integrations
POSTGRES_URL=

# Web frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Cron proxy routes in Next.js
API_CRON_TARGET_BASE_URL=http://localhost:8000
CRON_SECRET=replace-with-long-random-secret
